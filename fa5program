        "# FA 5: Function - Personal Calculator\n",
        "\n",
        "from google.colab import output\n",
        "\n",
        "# Add price of items purchased\n",
        "def calculate_total(price, quantity):\n",
        "  return price * quantity\n",
        "\n",
        "# Get user input\n",
        "item_price = float(input(\"Enter the price of the item: \"))\n",
        "output.clear()\n",
        "item_quantity = int(input(\"Enter the quantity of the item: \"))\n",
        "output.clear()\n",
        "\n",
        "# Function call\n",
        "result = calculate_total(item_price, item_quantity)\n",
        "\n",
        "# Display result\n",
        "print(\"The total price is: \", result)"
